---
// src/layouts/Layout.astro
interface Frontmatter {
  title?: string;
  description?: string;
  useKatex?: boolean;
}
interface Props extends Frontmatter {
  // Markdownページの `layout:` frontmatterから使われる場合、値はここに入る
  frontmatter?: Frontmatter;
}

const {
  title,
  description,
  useKatex = false,
} = Astro.props.frontmatter ?? Astro.props;
const displayTitle = title ? `${title} - hakhatz.dev` : "hakhatz.dev";
const displayDescription = description || "白捌(hakhatz)のウェブサイトです。";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="icon" href="/images/hakhatz2486_32.ico" sizes="32x32" />
    <link rel="icon" href="/images/hakhatz2486_48.ico" sizes="48x48" />

    <title>{displayTitle}</title>
    <meta name="description" content={displayDescription} />

    {
      useKatex && (
        <>
          <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/katex@0.17.0/dist/katex.min.css"
            integrity="sha384-vlBdW0r3AcZO/HboRPznQNowvexd3fY8qHOWkBi5q7KGgqJ+F48+DceybYmrVbmB"
            crossorigin="anonymous"
          />
          <script
            defer
            src="https://cdn.jsdelivr.net/npm/katex@0.17.0/dist/katex.min.js"
            integrity="sha384-AtrdNsnxl/75rvBneBVH7DtOvCxSVahR2zWqle1coBKd8DEmLoviqNeJSx64gNAs"
            crossorigin="anonymous"
          />
          <script
            defer
            src="https://cdn.jsdelivr.net/npm/katex@0.17.0/dist/contrib/auto-render.min.js"
            integrity="sha384-bjyGPfbij8/NDKJhSGZNP/khQVgtHUE5exjm4Ydllo42FwIgYsdLO2lXGmRBf5Mz"
            crossorigin="anonymous"
            onload="renderMathInElement(document.body)"
          />
        </>
      )
    }
  </head>
  <body>
    <header>
      <p><a href="/">hakhatz.dev</a></p>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; 2026 hakhatz</p>
      <p>
        <a href="https://github.com/hakhatz2486/hakhatz-dev"
          >GitHub - hakhatz2486/hakhatz-dev</a
        >
      </p>
    </footer>
  </body>
</html>
